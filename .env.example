# ============================================================
# ffxiv-trader — infrastructure config only.
#
# Game/player settings (home world, tax city, scan thresholds, retainers,
# auto-rescan, etc.) are stored in data.db and edited via the in-app
# Settings panel — not here. On first run they are seeded from the built-in
# defaults in src/app/core/config.py.
# ============================================================

# ============================================================
# API endpoints
# ============================================================
UNIVERSALIS_BASE=https://universalis.app/api/v2
XIVAPI_BASE=https://v2.xivapi.com/api
FFXIVCOLLECT_BASE=https://ffxivcollect.com/api
TEAMCRAFT_ITEMS_URL=https://raw.githubusercontent.com/ffxiv-teamcraft/ffxiv-teamcraft/master/libs/data/src/lib/json/items.json
USER_AGENT=ffxiv-trader/0.1

# ============================================================
# Rate limits (per upstream API)
# Universalis: 25 req/s sustained, 8 simultaneous connections per IP.
# XIVAPI v2: undocumented; keep conservative.
# ============================================================
UNIVERSALIS_RATE_PER_SEC=20
UNIVERSALIS_MAX_CONCURRENT=8
XIVAPI_RATE_PER_SEC=10
XIVAPI_MAX_CONCURRENT=4
